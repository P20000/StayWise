# ==========================================
node_modules/
dist/
build/
.cache/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ==========================================
# Editor, Agent & OS Files
# ==========================================
.gemini/
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log
